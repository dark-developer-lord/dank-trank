{
  "name": "@adas/dank-trank",
  "version": "2.0.0",
  "description": "From idea to live app in 1 command. Auto-detect your stack, generate production-ready Docker, Nginx, and CI/CD.",
  "type": "module",
  "bin": {
    "dank-trank": "./dist/cli/index.js",
    "dt": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "dist/templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "devops",
    "docker",
    "dockerfile",
    "nginx",
    "ci-cd",
    "github-actions",
    "startup",
    "cli",
    "scaffolding",
    "django",
    "fastapi",
    "nodejs",
    "express",
    "nextjs",
    "production-ready",
    "infrastructure"
  ],
  "author": "Adas <adas@dank-trank.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dark-developer-lord/dank-trank.git"
  },
  "bugs": {
    "url": "https://github.com/dark-developer-lord/dank-trank/issues"
  },
  "homepage": "https://github.com/dark-developer-lord/dank-trank#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "enquirer": "^2.4.1",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
