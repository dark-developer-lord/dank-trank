name: Deploy {{projectName}}

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  IMAGE_NAME: {{projectName}}
  REGISTRY: ghcr.io

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"
{{#if usePnpm}}
      - name: Install pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 9
{{/if}}

      - name: Install dependencies
        run: {{installCmd}}

      - name: Run tests
        run: {{testCmd}}

  build:
    needs: test
    runs-on: ubuntu-latest
    if: github.ref == 'refs/heads/main'
    steps:
      - uses: actions/checkout@v4

      - name: Build Docker image
        run: docker build -t $IMAGE_NAME .

      - name: Run container health check
        run: |
          docker run -d --name test-container -p {{port}}:{{port}} $IMAGE_NAME
          for i in $(seq 1 10); do
            if curl -sf http://localhost:{{port}}/ > /dev/null 2>&1; then
              echo "Health check passed on attempt $i"
              exit 0
            fi
            echo "Attempt $i failed, retrying in 3s..."
            sleep 3
          done
          echo "Health check failed after 10 attempts"
          docker logs test-container
          exit 1

      - name: Push to GHCR
        if: github.event_name == 'push'
        run: |
          echo "${{"{{"}} secrets.GITHUB_TOKEN {{"}}"}}" | docker login $REGISTRY -u ${{"{{"}} github.actor {{"}}"}} --password-stdin
          docker tag $IMAGE_NAME $REGISTRY/${{"{{"}} github.repository_owner {{"}}"}}/$IMAGE_NAME:latest
          docker push $REGISTRY/${{"{{"}} github.repository_owner {{"}}"}}/$IMAGE_NAME:latest

      - name: Cleanup
        if: always()
        run: docker stop test-container 2>/dev/null && docker rm test-container 2>/dev/null || true
