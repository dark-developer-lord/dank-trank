apiVersion: v1
kind: Service
metadata:
  name: {{projectName}}
  namespace: {{namespace}}
  labels:
    app.kubernetes.io/name: {{projectName}}
    app.kubernetes.io/managed-by: dank-trank
spec:
  selector:
    app: {{projectName}}
  ports:
    - name: http
      port: 80
      targetPort: {{port}}
      protocol: TCP
  type: ClusterIP
