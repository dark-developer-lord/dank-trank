apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{projectName}}
  namespace: {{namespace}}
  labels:
    app.kubernetes.io/name: {{projectName}}
    app.kubernetes.io/managed-by: dank-trank
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {{projectName}}
  minReplicas: {{minReplicas}}
  maxReplicas: {{maxReplicas}}
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: 70
    - type: Resource
      resource:
        name: memory
        target:
          type: Utilization
          averageUtilization: 80
