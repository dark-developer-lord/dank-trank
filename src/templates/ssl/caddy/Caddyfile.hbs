# Generated by dank-trank — Caddyfile (automatic HTTPS via Let's Encrypt)
# Install Caddy: https://caddyserver.com/docs/install

{{domain}} {
    reverse_proxy localhost:{{port}}

    # Automatic TLS: Caddy obtains and renews certs from Let's Encrypt
    tls {{email}}

    # Compression
    encode zstd gzip

    # Security headers
    header {
        Strict-Transport-Security "max-age=15768000; includeSubDomains; preload"
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Static files (adjust path as needed)
    # handle_path /static/* {
    #     root * /app/staticfiles
    #     file_server
    # }

    log {
        output file /var/log/caddy/{{projectName}}.log
        format json
    }
}
