# Generated by dank-trank — Root Docker Compose for monorepo
# Runs all services together. Each service's Dockerfile lives in its package directory.

version: "3.9"

services:
  {{#each services}}
  {{name}}:
    build:
      context: ./{{path}}
      dockerfile: Dockerfile
    container_name: {{../projectName}}-{{name}}
    restart: unless-stopped
    environment:
      - PORT={{port}}
    networks:
      - {{../projectName}}-network
    {{#if isFirst}}
    labels:
      - "traefik.enable=true"
    {{/if}}
  {{/each}}

  nginx:
    image: nginx:1.27-alpine
    container_name: {{projectName}}-nginx
    ports:
      - "80:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - {{projectName}}-network
    depends_on:
      {{#each services}}
      - {{name}}
      {{/each}}
    restart: unless-stopped

networks:
  {{projectName}}-network:
    driver: bridge
